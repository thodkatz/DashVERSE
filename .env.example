# Postgres
POSTGRES_DB=dashverse
POSTGRES_USER=dashverse
POSTGRES_PASSWORD=change-me-postgres

# JWT secret shared between PostgREST and auth-service
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-jwt-secret

# Superset
# Generate with: openssl rand -hex 32
SUPERSET_SECRET_KEY=change-me-superset-secret-key
SUPERSET_ADMIN_PASSWORD=change-me-admin

# External URL the user's browser hits Superset on (used by demo-portal embeds)
SUPERSET_EXTERNAL_URL=http://localhost:8088
